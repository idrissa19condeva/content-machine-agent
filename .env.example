# === Base ===
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=true

# === Database ===
DATABASE_URL=postgresql+asyncpg://cm_user:cm_password@localhost:5432/content_machine

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Storage (MinIO / S3) ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=content-machine
S3_REGION=us-east-1

# === LLM ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# === TTS ===
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
TTS_PROVIDER=elevenlabs

# === Plateformes sociales ===
TIKTOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# === Monitoring ===
SENTRY_DSN=
LOG_LEVEL=INFO
